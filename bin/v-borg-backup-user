#!/bin/bash
# info: backup user with borg incremental
# options: USER [NOTIFY]
#
# This command creates an incremental backup of a user using Borg Backup.
# It backs up the user's home directory, databases, and myVesta configuration.

#----------------------------------------------------------#
#                Variable & Argument Definition            #
#----------------------------------------------------------#

# Arguments
user=$1
notify=${2-no}

# Source shared functions
if [ -f "/usr/local/vesta/func/borg.sh" ]; then
    source /usr/local/vesta/func/borg.sh
else
    # Try local development path
    SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null && pwd )"
    NEW_BORG_DIR="$(dirname "$SCRIPT_DIR")"
    source "$NEW_BORG_DIR/func/borg.sh"
fi

# Source myVesta environment
source /etc/profile.d/vesta.sh 2>/dev/null || source /etc/profile

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_root
check_borg_installed
source_borg_config
ensure_log_dir

# Check arguments
if [ -z "$user" ]; then
    echo "Usage: v-borg-backup-user USER [NOTIFY]"
    echo "Error: USER argument is required"
    exit 1
fi

# Check if user exists
if ! check_user_exists "$user"; then
    echo "Error: User '$user' does not exist"
    exit 1
fi

# Check if user is suspended
if check_user_suspended "$user"; then
    echo "User '$user' is suspended, skipping backup"
    exit 0
fi

# Check if user is in excluded list
if [[ ",$EXCLUDED_USERS," == *",$user,"* ]]; then
    echo "User '$user' is in excluded list, skipping backup"
    exit 0
fi

# Load per-user config
if ! load_user_borg_config "$user"; then
    echo "Error: Failed to load per-user config for $user"
    exit 1
fi

# Check if backup is enabled for this user
if [ "$BORG_BACKUP_ENABLED" = "no" ]; then
    echo "User '$user' has backups disabled in per-user config, skipping backup"
    exit 0
fi

#----------------------------------------------------------#
#                    Backup Execution                      #
#----------------------------------------------------------#

START_TIME=$(date +%s)
ARCHIVE_DATE=$(get_archive_date)
LOG_FILE="$LOG_DIR/backup-user-$user-$ARCHIVE_DATE.log"

echo "$(get_timestamp) Starting backup for user: $user" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Backup mode: $BACKUP_MODE" | tee -a "$LOG_FILE"

# Build repository paths
USER_REPO=$(build_borg_repo_path "user" "$user")
DB_REPO=$(build_borg_repo_path "db" "$user")
VESTA_REPO=$(build_borg_repo_path "vesta" "")  # Shared repo, no user identifier

echo "$(get_timestamp) User repository: $USER_REPO" | tee -a "$LOG_FILE"
echo "$(get_timestamp) DB repository: $DB_REPO" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Vesta repository: $VESTA_REPO" | tee -a "$LOG_FILE"

# Initialize repositories if needed
init_repo_if_needed "$USER_REPO" >> "$LOG_FILE" 2>&1
init_repo_if_needed "$DB_REPO" >> "$LOG_FILE" 2>&1
init_repo_if_needed "$VESTA_REPO" >> "$LOG_FILE" 2>&1

#----------------------------------------------------------#
#                Backup User Home Directory                #
#----------------------------------------------------------#

echo "$(get_timestamp) ========== BACKING UP USER HOME DIRECTORY ==========" | tee -a "$LOG_FILE"

# Build exclusion arguments
EXCLUDE_ARGS=$(build_user_exclude_args "$user")

# Create backup archive
ARCHIVE_NAME="$ARCHIVE_DATE"

echo "$(get_timestamp) Creating archive: $USER_REPO::$ARCHIVE_NAME" | tee -a "$LOG_FILE"

eval borg create \
    $OPTIONS_CREATE \
    $EXCLUDE_ARGS \
    "$USER_REPO::$ARCHIVE_NAME" \
    "$HOME_DIR/$user" \
    >> "$LOG_FILE" 2>&1

if [ $? -eq 0 ]; then
    echo "$(get_timestamp) Home directory backup completed successfully" | tee -a "$LOG_FILE"
else
    echo "$(get_timestamp) Error: Home directory backup failed" | tee -a "$LOG_FILE"
    BACKUP_FAILED=1
fi

# Prune old archives
echo "$(get_timestamp) Pruning old archives..." | tee -a "$LOG_FILE"
borg prune $OPTIONS_PRUNE "$USER_REPO" >> "$LOG_FILE" 2>&1

#----------------------------------------------------------#
#                Backup myVesta Configuration              #
#----------------------------------------------------------#

echo "$(get_timestamp) ========== BACKING UP MYVESTA CONFIGURATION ==========" | tee -a "$LOG_FILE"

# Backup user's myVesta data
VESTA_USER_DIR="$VESTA_DIR/data/users/$user"

if [ -d "$VESTA_USER_DIR" ]; then
    # Vesta archive name format: USER-ARCHIVE_NAME (to allow multiple users in shared repo)
    VESTA_ARCHIVE_NAME="$user-$ARCHIVE_NAME"
    echo "$(get_timestamp) Creating archive: $VESTA_REPO::$VESTA_ARCHIVE_NAME" | tee -a "$LOG_FILE"
    
    borg create \
        $OPTIONS_CREATE \
        "$VESTA_REPO::$VESTA_ARCHIVE_NAME" \
        "$VESTA_USER_DIR" \
        >> "$LOG_FILE" 2>&1
    
    if [ $? -eq 0 ]; then
        echo "$(get_timestamp) myVesta config backup completed successfully" | tee -a "$LOG_FILE"
    else
        echo "$(get_timestamp) Error: myVesta config backup failed" | tee -a "$LOG_FILE"
        BACKUP_FAILED=1
    fi
    
    # Prune old vesta archives
    borg prune $OPTIONS_PRUNE "$VESTA_REPO" >> "$LOG_FILE" 2>&1
fi

#----------------------------------------------------------#
#                Backup Databases                          #
#----------------------------------------------------------#

echo "$(get_timestamp) ========== BACKING UP DATABASES ==========" | tee -a "$LOG_FILE"

DB_COUNT=0
DATABASES=$(get_user_mysql_databases "$user")

if [ -n "$DATABASES" ]; then
    while IFS= read -r database; do
        if [ -z "$database" ]; then
            continue
        fi
        
        DB_ARCHIVE_NAME="$database-$ARCHIVE_DATE"
        echo "$(get_timestamp) Backing up database: $database" | tee -a "$LOG_FILE"
        
        # Dump database and pipe directly to borg
        mysqldump "$database" --opt --routines --skip-comments 2>>"$LOG_FILE" | \
            borg create $OPTIONS_CREATE "$DB_REPO::$DB_ARCHIVE_NAME" - \
            >> "$LOG_FILE" 2>&1
        
        if [ $? -eq 0 ]; then
            echo "$(get_timestamp) Database $database backed up successfully" | tee -a "$LOG_FILE"
            ((DB_COUNT++))
            
            # Prune old database archives (keep only archives for this specific database)
            borg prune $OPTIONS_PRUNE --prefix "$database-" "$DB_REPO" >> "$LOG_FILE" 2>&1
        else
            echo "$(get_timestamp) Error: Database $database backup failed" | tee -a "$LOG_FILE"
            BACKUP_FAILED=1
        fi
    done <<< "$DATABASES"
    
    echo "$(get_timestamp) Total databases backed up: $DB_COUNT" | tee -a "$LOG_FILE"
else
    echo "$(get_timestamp) No databases found for user $user" | tee -a "$LOG_FILE"
fi

#----------------------------------------------------------#
#                Backup Summary                            #
#----------------------------------------------------------#

END_TIME=$(date +%s)
RUNTIME=$((END_TIME - START_TIME))
RUNTIME_MIN=$((RUNTIME / 60))

if [ $RUNTIME_MIN -lt 1 ]; then
    RUNTIME_MIN=1
fi

echo "$(get_timestamp) ========== BACKUP SUMMARY ==========" | tee -a "$LOG_FILE"
echo "$(get_timestamp) User: $user" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Archive date: $ARCHIVE_DATE" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Databases backed up: $DB_COUNT" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Runtime: $RUNTIME_MIN minute(s)" | tee -a "$LOG_FILE"

#----------------------------------------------------------#
#                Sync to Remote (if both mode)              #
#----------------------------------------------------------#

if [ "$BACKUP_MODE" = "both" ] && [ -z "$BACKUP_FAILED" ]; then
    echo "$(get_timestamp) ========== SYNCING TO REMOTE SERVER ==========" | tee -a "$LOG_FILE"
    
    if [ "$REMOTE_SYNC_METHOD" = "rsync" ]; then
        # Build remote paths
        REMOTE_BASE="ssh://${REMOTE_BACKUP_SERVER}:${REMOTE_BACKUP_PORT}${REMOTE_BACKUP_DIR}"
        REMOTE_USER_REPO="${REMOTE_BASE}/home/$user"
        REMOTE_DB_REPO="${REMOTE_BASE}/db/$user"
        REMOTE_VESTA_REPO="${REMOTE_BASE}/vesta"
        
        # Sync user repo
        echo "$(get_timestamp) Syncing user repository to remote..." | tee -a "$LOG_FILE"
        if [ -n "$REMOTE_BACKUP_PASSWORD" ]; then
            rsync -avz --delete -e "sshpass -p '$REMOTE_BACKUP_PASSWORD' ssh -p $REMOTE_BACKUP_PORT -o StrictHostKeyChecking=no" \
                "$USER_REPO/" "${REMOTE_BACKUP_SERVER}:${REMOTE_BACKUP_DIR}/home/$user/" >> "$LOG_FILE" 2>&1
        else
            rsync -avz --delete -e "ssh -p $REMOTE_BACKUP_PORT -o StrictHostKeyChecking=no" \
                "$USER_REPO/" "${REMOTE_BACKUP_SERVER}:${REMOTE_BACKUP_DIR}/home/$user/" >> "$LOG_FILE" 2>&1
        fi
        
        if [ $? -eq 0 ]; then
            echo "$(get_timestamp) User repository synced successfully" | tee -a "$LOG_FILE"
        else
            echo "$(get_timestamp) Warning: User repository sync failed" | tee -a "$LOG_FILE"
        fi
        
        # Sync DB repo
        echo "$(get_timestamp) Syncing database repository to remote..." | tee -a "$LOG_FILE"
        if [ -n "$REMOTE_BACKUP_PASSWORD" ]; then
            rsync -avz --delete -e "sshpass -p '$REMOTE_BACKUP_PASSWORD' ssh -p $REMOTE_BACKUP_PORT -o StrictHostKeyChecking=no" \
                "$DB_REPO/" "${REMOTE_BACKUP_SERVER}:${REMOTE_BACKUP_DIR}/db/$user/" >> "$LOG_FILE" 2>&1
        else
            rsync -avz --delete -e "ssh -p $REMOTE_BACKUP_PORT -o StrictHostKeyChecking=no" \
                "$DB_REPO/" "${REMOTE_BACKUP_SERVER}:${REMOTE_BACKUP_DIR}/db/$user/" >> "$LOG_FILE" 2>&1
        fi
        
        if [ $? -eq 0 ]; then
            echo "$(get_timestamp) Database repository synced successfully" | tee -a "$LOG_FILE"
        else
            echo "$(get_timestamp) Warning: Database repository sync failed" | tee -a "$LOG_FILE"
        fi
        
        # Sync Vesta repo (only user's archives)
        echo "$(get_timestamp) Syncing myVesta config to remote..." | tee -a "$LOG_FILE"
        if [ -n "$REMOTE_BACKUP_PASSWORD" ]; then
            rsync -avz -e "sshpass -p '$REMOTE_BACKUP_PASSWORD' ssh -p $REMOTE_BACKUP_PORT -o StrictHostKeyChecking=no" \
                "$VESTA_REPO/" "${REMOTE_BACKUP_SERVER}:${REMOTE_BACKUP_DIR}/vesta/" >> "$LOG_FILE" 2>&1
        else
            rsync -avz -e "ssh -p $REMOTE_BACKUP_PORT -o StrictHostKeyChecking=no" \
                "$VESTA_REPO/" "${REMOTE_BACKUP_SERVER}:${REMOTE_BACKUP_DIR}/vesta/" >> "$LOG_FILE" 2>&1
        fi
        
        if [ $? -eq 0 ]; then
            echo "$(get_timestamp) myVesta config synced successfully" | tee -a "$LOG_FILE"
        else
            echo "$(get_timestamp) Warning: myVesta config sync failed" | tee -a "$LOG_FILE"
        fi
    else
        # REMOTE_SYNC_METHOD="borg" - create separate remote repos (not implemented yet)
        echo "$(get_timestamp) Borg sync method not yet implemented, skipping remote sync" | tee -a "$LOG_FILE"
    fi
fi

if [ -n "$BACKUP_FAILED" ]; then
    echo "$(get_timestamp) Status: FAILED (see log for details)" | tee -a "$LOG_FILE"
    BACKUP_STATUS="FAILED"
else
    echo "$(get_timestamp) Status: SUCCESS" | tee -a "$LOG_FILE"
    BACKUP_STATUS="SUCCESS"
fi

#----------------------------------------------------------#
#                Notifications                             #
#----------------------------------------------------------#

if [ "$notify" = "yes" ] || [ -n "$NOTIFY_ADMIN_BACKUP" ]; then
    SUBJECT="Backup $BACKUP_STATUS: User $user"
    BODY=$(cat "$LOG_FILE")
    
    if [ "$notify" = "yes" ]; then
        # Notify user
        USER_EMAIL=$(/usr/local/vesta/bin/v-list-user "$user" plain | awk '{print $2}')
        if [ -n "$USER_EMAIL" ]; then
            send_notification "$SUBJECT" "$BODY" "$USER_EMAIL"
        fi
    fi
    
    if [ -n "$NOTIFY_ADMIN_BACKUP" ] && [ "$BACKUP_STATUS" = "FAILED" ]; then
        # Notify admin on failure
        send_notification "$SUBJECT" "$BODY" "$NOTIFY_ADMIN_BACKUP"
    fi
fi

#----------------------------------------------------------#
#                Logging                                   #
#----------------------------------------------------------#

log_event "OK" "Backup completed for user $user (status: $BACKUP_STATUS)"

# Exit with appropriate code
if [ -n "$BACKUP_FAILED" ]; then
    exit 1
fi

exit 0
