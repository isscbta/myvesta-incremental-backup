#!/bin/bash
# info: backup all users with borg incremental
# options: NONE
#
# This command backs up all active (non-suspended) users using Borg incremental backup.

#----------------------------------------------------------#
#                Variable Definition                       #
#----------------------------------------------------------#

# Source shared functions
if [ -f "/usr/local/vesta/func/borg.sh" ]; then
    source /usr/local/vesta/func/borg.sh
else
    # Try local development path
    SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null && pwd )"
    NEW_BORG_DIR="$(dirname "$SCRIPT_DIR")"
    source "$NEW_BORG_DIR/func/borg.sh"
fi

# Source myVesta environment
source /etc/profile.d/vesta.sh 2>/dev/null || source /etc/profile

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_root
check_borg_installed
source_borg_config
ensure_log_dir

#----------------------------------------------------------#
#                    Main Execution                        #
#----------------------------------------------------------#

START_TIME=$(date +%s)
ARCHIVE_DATE=$(get_archive_date)
LOG_FILE="$LOG_DIR/backup-all-users-$ARCHIVE_DATE.log"

echo "$(get_timestamp) ==================== STARTING BACKUP FOR ALL USERS ====================" | tee "$LOG_FILE"
echo "$(get_timestamp) Backup mode: $BACKUP_MODE" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Log file: $LOG_FILE" | tee -a "$LOG_FILE"
echo "" | tee -a "$LOG_FILE"

#----------------------------------------------------------#
#                MySQL Repair (Optional)                   #
#----------------------------------------------------------#

if [ "$MYSQL_REPAIR_BEFORE_BACKUP" = "yes" ]; then
    echo "$(get_timestamp) Running MySQL repair..." | tee -a "$LOG_FILE"
    mysqlrepair --all-databases --check --auto-repair >> "$LOG_FILE" 2>&1
    echo "$(get_timestamp) MySQL repair completed" | tee -a "$LOG_FILE"
    echo "" | tee -a "$LOG_FILE"
fi

#----------------------------------------------------------#
#                Backup All Users                          #
#----------------------------------------------------------#

TOTAL_USERS=0
SUCCESSFUL_USERS=0
FAILED_USERS=0
SKIPPED_USERS=0

# Get list of all users
USERS=$(get_user_list)

for user in $USERS; do
    echo "$(get_timestamp) ===== Processing user: $user =====" | tee -a "$LOG_FILE"
    
    # Check if user is in excluded list
    if [[ ",$EXCLUDED_USERS," == *",$user,"* ]]; then
        echo "$(get_timestamp) User $user is excluded, skipping" | tee -a "$LOG_FILE"
        ((SKIPPED_USERS++))
        continue
    fi
    
    # Check if user is suspended
    if check_user_suspended "$user"; then
        echo "$(get_timestamp) User $user is suspended, skipping" | tee -a "$LOG_FILE"
        ((SKIPPED_USERS++))
        continue
    fi
    
    # Load per-user config
    if ! load_user_borg_config "$user" 2>>"$LOG_FILE"; then
        echo "$(get_timestamp) Warning: Failed to load per-user config for $user, using defaults" | tee -a "$LOG_FILE"
    fi
    
    # Check if backup is enabled for this user
    if [ "$BORG_BACKUP_ENABLED" = "no" ]; then
        echo "$(get_timestamp) User $user has backups disabled in per-user config, skipping" | tee -a "$LOG_FILE"
        ((SKIPPED_USERS++))
        continue
    fi
    
    ((TOTAL_USERS++))
    
    # Run backup for this user
    "$SCRIPT_DIR/v-borg-backup-user" "$user" no >> "$LOG_FILE" 2>&1
    
    if [ $? -eq 0 ]; then
        echo "$(get_timestamp) User $user backup completed successfully" | tee -a "$LOG_FILE"
        ((SUCCESSFUL_USERS++))
    else
        echo "$(get_timestamp) User $user backup FAILED" | tee -a "$LOG_FILE"
        ((FAILED_USERS++))
    fi
    
    echo "" | tee -a "$LOG_FILE"
done

#----------------------------------------------------------#
#                Backup Summary                            #
#----------------------------------------------------------#

END_TIME=$(date +%s)
RUNTIME=$((END_TIME - START_TIME))
RUNTIME_MIN=$((RUNTIME / 60))

if [ $RUNTIME_MIN -lt 1 ]; then
    RUNTIME_MIN=1
fi

echo "$(get_timestamp) ==================== BACKUP SUMMARY ====================" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Total users processed: $TOTAL_USERS" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Successful: $SUCCESSFUL_USERS" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Failed: $FAILED_USERS" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Skipped: $SKIPPED_USERS" | tee -a "$LOG_FILE"
echo "$(get_timestamp) Runtime: $RUNTIME_MIN minute(s)" | tee -a "$LOG_FILE"

if [ $FAILED_USERS -gt 0 ]; then
    echo "$(get_timestamp) Status: COMPLETED WITH ERRORS" | tee -a "$LOG_FILE"
    FINAL_STATUS="COMPLETED WITH ERRORS"
else
    echo "$(get_timestamp) Status: SUCCESS" | tee -a "$LOG_FILE"
    FINAL_STATUS="SUCCESS"
fi

#----------------------------------------------------------#
#                Notifications                             #
#----------------------------------------------------------#

if [ -n "$NOTIFY_ADMIN_BACKUP" ]; then
    HOST=$(hostname 2>/dev/null || echo "server")
    if [ "$FINAL_STATUS" = "SUCCESS" ]; then
        SUBJECT="[Borg Backup SUCCESS] $HOST - $SUCCESSFUL_USERS users backed up"
    else
        SUBJECT="[Borg Backup FAILED] $HOST - $FAILED_USERS failed, $SUCCESSFUL_USERS ok"
    fi
    
    BODY=""
    BODY="${BODY}============================================\n"
    BODY="${BODY}Borg Backup Report - $(date '+%Y-%m-%d %H:%M:%S')\n"
    BODY="${BODY}Host: $HOST\n"
    BODY="${BODY}Status: $FINAL_STATUS\n"
    BODY="${BODY}--------------------------------------------\n"
    BODY="${BODY}Total: $TOTAL_USERS | Success: $SUCCESSFUL_USERS | Failed: $FAILED_USERS | Skipped: $SKIPPED_USERS\n"
    BODY="${BODY}Runtime: ${RUNTIME_MIN} min\n"
    BODY="${BODY}============================================\n\n"
    BODY="${BODY}--- Backup Log ---\n"
    BODY="${BODY}$(cat "$LOG_FILE")\n"
    
    # Include global report if configured
    if [ -n "$NOTIFY_GLOBAL_REPORT" ] && [ "$NOTIFY_GLOBAL_REPORT" != "never" ]; then
        TODAY_WDAY=$(date +%w)
        SEND_GLOBAL="no"
        if [ "$NOTIFY_GLOBAL_REPORT" = "daily" ]; then
            SEND_GLOBAL="yes"
        elif [ "$NOTIFY_GLOBAL_REPORT" = "weekly" ] && [ "$TODAY_WDAY" = "${NOTIFY_GLOBAL_REPORT_WEEKDAY:-1}" ]; then
            SEND_GLOBAL="yes"
        fi
        if [ "$SEND_GLOBAL" = "yes" ]; then
            BODY="${BODY}\n--- Global Report ---\n"
            BODY="${BODY}$(/usr/local/vesta/bin/v-borg-report-global email 2>/dev/null)\n"
        fi
    fi
    
    echo -e "$BODY" | send_notification_stdin "$SUBJECT" "$NOTIFY_ADMIN_BACKUP"
fi

#----------------------------------------------------------#
#                Logging                                   #
#----------------------------------------------------------#

log_event "OK" "Backup all users completed ($SUCCESSFUL_USERS successful, $FAILED_USERS failed, $SKIPPED_USERS skipped)"

# Exit with appropriate code
if [ $FAILED_USERS -gt 0 ]; then
    exit 1
fi

exit 0

