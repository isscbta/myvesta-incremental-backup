#!/bin/bash
# info: delete user backup archive
# options: USER ARCHIVE
#
# This command deletes a specific backup archive for a user.

#----------------------------------------------------------#
#                Variable Definition                       #
#----------------------------------------------------------#

# Arguments
user=$1
archive=$2

# Source shared functions
if [ -f "/usr/local/vesta/func/borg.sh" ]; then
    source /usr/local/vesta/func/borg.sh
else
    # Try local development path
    SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null && pwd )"
    NEW_BORG_DIR="$(dirname "$SCRIPT_DIR")"
    source "$NEW_BORG_DIR/func/borg.sh"
fi

# Source myVesta environment
source /etc/profile.d/vesta.sh 2>/dev/null || source /etc/profile

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_root
check_borg_installed
source_borg_config

# Check arguments
if [ -z "$user" ] || [ -z "$archive" ]; then
    echo "Usage: v-borg-delete-backup USER ARCHIVE"
    echo ""
    echo "Arguments:"
    echo "  USER    - Username"
    echo "  ARCHIVE - Archive name (e.g., 2025-10-16_17-43-57)"
    echo ""
    echo "Example:"
    echo "  v-borg-delete-backup admin 2025-10-16_17-43-57"
    echo ""
    echo "To see available archives:"
    echo "  v-borg-list-backups admin"
    exit 1
fi

# Check if user exists
if ! check_user_exists "$user"; then
    echo "Error: User '$user' does not exist"
    exit 1
fi

# Build repository paths
USER_REPO=$(build_borg_repo_path "user" "$user")
DB_REPO=$(build_borg_repo_path "db" "$user")
VESTA_REPO=$(build_borg_repo_path "vesta" "")  # Shared repo, no user identifier

# Check if archive exists in user repo
if ! check_archive_exists "$USER_REPO" "$archive"; then
    echo "Error: Archive '$archive' not found for user '$user'"
    echo "Available archives:"
    borg list "$USER_REPO" 2>/dev/null | awk '{print $1}'
    exit 1
fi

#----------------------------------------------------------#
#                Confirmation                              #
#----------------------------------------------------------#

echo "WARNING: This will permanently delete the backup archive!"
echo "User: $user"
echo "Archive: $archive"
echo ""
read -p "Are you sure you want to delete this archive? [y/N]: " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Deletion cancelled"
    exit 0
fi

#----------------------------------------------------------#
#                Delete Archives                           #
#----------------------------------------------------------#

echo "$(get_timestamp) Deleting archives for $user::$archive"

# Delete user home archive
echo "$(get_timestamp) Deleting user home archive..."
borg delete "$USER_REPO::$archive" 2>&1

if [ $? -eq 0 ]; then
    echo "$(get_timestamp) User home archive deleted successfully"
else
    echo "$(get_timestamp) Error: Failed to delete user home archive"
    DELETE_FAILED=1
fi

# Delete vesta config archive (format: USER-ARCHIVE_NAME)
VESTA_ARCHIVE_NAME="$user-$archive"
if check_archive_exists "$VESTA_REPO" "$VESTA_ARCHIVE_NAME"; then
    echo "$(get_timestamp) Deleting myVesta config archive..."
    borg delete "$VESTA_REPO::$VESTA_ARCHIVE_NAME" 2>&1
    
    if [ $? -eq 0 ]; then
        echo "$(get_timestamp) myVesta config archive deleted successfully"
    else
        echo "$(get_timestamp) Warning: Failed to delete myVesta config archive"
    fi
fi

# Delete database archives (format: DBNAME-YYYY-MM-DD)
echo "$(get_timestamp) Checking for database archives..."
DB_ARCHIVES=$(borg list "$DB_REPO" 2>/dev/null | grep -- "-$archive" | awk '{print $1}')

if [ -n "$DB_ARCHIVES" ]; then
    while IFS= read -r db_archive; do
        if [ -z "$db_archive" ]; then
            continue
        fi
        
        echo "$(get_timestamp) Deleting database archive: $db_archive"
        borg delete "$DB_REPO::$db_archive" 2>&1
        
        if [ $? -eq 0 ]; then
            echo "$(get_timestamp) Database archive deleted successfully"
        else
            echo "$(get_timestamp) Warning: Failed to delete database archive $db_archive"
        fi
    done <<< "$DB_ARCHIVES"
else
    echo "$(get_timestamp) No database archives found for this date"
fi

#----------------------------------------------------------#
#                Summary                                   #
#----------------------------------------------------------#

if [ -n "$DELETE_FAILED" ]; then
    echo "$(get_timestamp) Deletion completed with errors"
    log_event "WARNING" "Backup archive deletion for $user::$archive completed with errors"
    exit 1
else
    echo "$(get_timestamp) Deletion completed successfully"
    log_event "OK" "Backup archive deleted: $user::$archive"
    exit 0
fi


