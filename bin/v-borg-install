#!/bin/bash
# info: install borg backup system
# options: NONE
#
# This script installs and configures the Borg incremental backup system for myVesta.
# Usage: wget this script to /usr/local/vesta/bin/, chmod +x it, and run it.

#----------------------------------------------------------#
#                Color Definitions                         #
#----------------------------------------------------------#

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

#----------------------------------------------------------#
#                Helper Functions                          #
#----------------------------------------------------------#

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_info() {
    echo -e "${YELLOW}→${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

print_header() {
    echo ""
    echo "=========================================="
    echo "$1"
    echo "=========================================="
    echo ""
}

#----------------------------------------------------------#
#                Configuration                             #
#----------------------------------------------------------#

# GitHub repository
GITHUB_RAW_URL="https://raw.githubusercontent.com/isscbta/myvesta-incremental-backup/main"

# File URLs (repo root has conf/, func/, bin/ directly)
CONF_URL="${GITHUB_RAW_URL}/conf/borg.conf"
FUNC_URL="${GITHUB_RAW_URL}/func/borg.sh"

# Scripts to download
SCRIPTS=(
    "v-borg-backup-system"
    "v-borg-backup-user"
    "v-borg-backup-users"
    "v-borg-delete-backup"
    "v-borg-list-backups"
    "v-borg-restore-user"
    "v-borg-status"
    "v-borg-report"
    "v-borg-report-global"
    "v-borg-checkup"
    "v-borg-restore-checkup"
    "v-borg-backup-prune"
    "v-borg-update"
)

#----------------------------------------------------------#
#                Verifications                             #
#----------------------------------------------------------#

# Check if running as root
if [ "$(id -u)" != "0" ]; then
    print_error "This script must be run as root"
    exit 1
fi

# Check if myVesta is installed
if [ ! -d "/usr/local/vesta" ]; then
    print_error "myVesta Control Panel is not installed"
    exit 1
fi

print_header "myVesta Borg Incremental Backup Installer"

#----------------------------------------------------------#
#                Detect Debian Version                     #
#----------------------------------------------------------#

print_info "Detecting Debian version..."

if [ -f /etc/debian_version ]; then
    DEBIAN_VERSION=$(cat /etc/debian_version | cut -d. -f1)
    print_success "Debian version: $DEBIAN_VERSION"
else
    print_error "This system does not appear to be running Debian"
    exit 1
fi

#----------------------------------------------------------#
#                Install Borg Backup                       #
#----------------------------------------------------------#

print_header "Installing Borg Backup"

# Check if Borg is already installed
if command -v borg &> /dev/null; then
    INSTALLED_VERSION=$(borg --version | grep -oP '\d+\.\d+\.\d+' | head -1)
    print_info "Borg Backup is already installed (version $INSTALLED_VERSION)"
else
    print_info "Updating package list..."
    apt-get update -qq
    
    print_info "Installing Borg Backup..."
    apt-get install -y borgbackup
    
    if [ $? -eq 0 ]; then
        BORG_VERSION=$(borg --version | grep -oP '\d+\.\d+\.\d+' | head -1)
        print_success "Borg Backup installed successfully (version $BORG_VERSION)"
    else
        print_error "Failed to install Borg Backup"
        exit 1
    fi
fi

# Install sshpass (always - needed for password-based remote backups)
if command -v sshpass &> /dev/null; then
    print_info "sshpass is already installed"
else
    print_info "Installing sshpass (for password-based remote backups)..."
    apt-get update -qq 2>/dev/null
    apt-get install -y sshpass 2>/dev/null
    if command -v sshpass &> /dev/null; then
        print_success "sshpass installed"
    else
        print_info "sshpass not available (only SSH key auth will work for remote)"
    fi
fi

#----------------------------------------------------------#
#                Create Directory Structure                #
#----------------------------------------------------------#

print_header "Setting Up Directory Structure"

# Create log directory
print_info "Creating log directory..."
mkdir -p /var/log/borg
chmod 750 /var/log/borg
print_success "Log directory created: /var/log/borg"

# Create backup directory
print_info "Creating backup directory..."
mkdir -p /backup/borg/{home,db,vesta,etc,scripts}
chmod 750 /backup/borg
print_success "Backup directory created: /backup/borg"

# Detect existing Borg repositories (migration / old installs)
EXISTING_BORG_REPO_DIRS=""
EXISTING_BORG_FOUND="no"
while IFS= read -r cfg; do
    [ -f "$cfg" ] || continue
    if grep -q '^repositoryversion' "$cfg" 2>/dev/null; then
        EXISTING_BORG_REPO_DIRS+="$(dirname "$cfg")"$'\n'
        EXISTING_BORG_FOUND="yes"
    fi
done < <(find /backup/borg -type f -name config 2>/dev/null)

if [ "$EXISTING_BORG_FOUND" = "yes" ]; then
    print_header "Existing Borg repositories detected"
    print_warning "Found Borg data under /backup/borg from a previous setup."
    echo ""
    while IFS= read -r repodir; do
        [ -z "$repodir" ] && continue
        print_info "  $repodir"
        if [ -f "$repodir/config" ]; then
            enc=$(grep '^encryption' "$repodir/config" 2>/dev/null | head -1 | tr -d '\r')
            [ -n "$enc" ] && echo "      $enc"
        fi
    done <<< "$(echo "$EXISTING_BORG_REPO_DIRS" | sort -u)"
    echo ""
    print_warning "If you use the NEW default (ENCRYPTION_MODE=\"none\", empty BORG_PASSPHRASE):"
    echo "  • Encrypted old repos will make backups FAIL in cron (passphrase cannot be entered)."
    echo ""
    echo "  Options:"
    echo "    A) Set BORG_PASSPHRASE and ENCRYPTION_MODE to match the old repos in borg.conf"
    echo "    B) Remove old repos and start clean (only if you do not need old archives):"
    echo ""
    echo "       rm -rf /backup/borg/home/* /backup/borg/db/* /backup/borg/vesta/* \\"
    echo "              /backup/borg/etc/* /backup/borg/scripts/*"
    echo "       mkdir -p /backup/borg/{home,db,vesta,etc,scripts} && chmod 750 /backup/borg"
    echo ""
fi

# Create temp directory for downloads
mkdir -p /tmp/borg-install
cd /tmp/borg-install

#----------------------------------------------------------#
#                Download Configuration                    #
#----------------------------------------------------------#

print_header "Downloading Configuration Files"

# Download borg.conf
print_info "Downloading borg.conf..."
if wget -q -O borg.conf "$CONF_URL" 2>/dev/null; then
    mv borg.conf /usr/local/vesta/conf/borg.conf
    chmod 600 /usr/local/vesta/conf/borg.conf
    chown root:root /usr/local/vesta/conf/borg.conf
    print_success "Configuration file installed: /usr/local/vesta/conf/borg.conf"
    print_info "Security: Set permissions to 600 (root only)"
else
    print_error "Failed to download borg.conf from $CONF_URL"
    print_error "Installation cannot continue without configuration file"
    exit 1
fi

# Download borg-backup.conf.template (per-user config template)
print_info "Downloading borg-backup.conf.template..."
if wget -q -O borg-backup.conf.template "${GITHUB_RAW_URL}/conf/borg-backup.conf.template" 2>/dev/null; then
    mv borg-backup.conf.template /usr/local/vesta/conf/borg-backup.conf.template
    chmod 644 /usr/local/vesta/conf/borg-backup.conf.template
    chown root:root /usr/local/vesta/conf/borg-backup.conf.template
    print_success "Per-user config template installed: /usr/local/vesta/conf/borg-backup.conf.template"
else
    print_error "Failed to download borg-backup.conf.template (optional, continuing)"
fi

#----------------------------------------------------------#
#                Download Function Library                 #
#----------------------------------------------------------#

print_header "Downloading Function Library"

print_info "Downloading borg.sh..."
if wget -q -O borg.sh "$FUNC_URL" 2>/dev/null; then
    mkdir -p /usr/local/vesta/func
    mv borg.sh /usr/local/vesta/func/borg.sh
    chmod 644 /usr/local/vesta/func/borg.sh
    print_success "Function library installed: /usr/local/vesta/func/borg.sh"
else
    print_error "Failed to download borg.sh from $FUNC_URL"
    print_error "Installation cannot continue without function library"
    exit 1
fi

#----------------------------------------------------------#
#                Download Bin Scripts                      #
#----------------------------------------------------------#

print_header "Downloading Borg Scripts"

for script in "${SCRIPTS[@]}"; do
    SCRIPT_URL="${GITHUB_RAW_URL}/bin/${script}"
    print_info "Downloading ${script}..."
    
    if wget -q -O "$script" "$SCRIPT_URL" 2>/dev/null; then
        mv "$script" "/usr/local/vesta/bin/$script"
        chmod 755 "/usr/local/vesta/bin/$script"
        print_success "  Installed: $script"
    else
        print_error "  Failed to download: $script"
    fi
done

print_success "All scripts installed to /usr/local/vesta/bin/"

# Clean up temp directory
cd /
rm -rf /tmp/borg-install

#----------------------------------------------------------#
#                Test Installation                         #
#----------------------------------------------------------#

print_header "Testing Installation"

print_info "Testing Borg installation..."
if borg --version &>/dev/null; then
    print_success "Borg is working"
else
    print_error "Borg test failed"
fi

print_info "Testing configuration..."
if [ -f /usr/local/vesta/conf/borg.conf ]; then
    source /usr/local/vesta/conf/borg.conf
    if [ -n "$BACKUP_DIR" ]; then
        print_success "Configuration loaded successfully"
    else
        print_error "Configuration test failed"
    fi
else
    print_error "Configuration file not found"
fi

#----------------------------------------------------------#
#                Installation Complete                     #
#----------------------------------------------------------#

print_header "Installation Complete!"

if [ "$EXISTING_BORG_FOUND" = "yes" ]; then
    print_warning "Reminder: existing Borg repos were reported above — fix passphrase or clean /backup/borg before relying on cron."
    echo ""
fi

echo ""
echo "⚠️  IMPORTANT: Configure your backup settings before use!"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "1. EDIT CONFIGURATION"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "   vi /usr/local/vesta/conf/borg.conf"
echo ""
echo "   Required settings:"
echo "   ┌─────────────────────────────────────────────────────┐"
echo "   │ BACKUP_MODE=\"local\"       # or \"remote\" or \"both\"  │"
echo "   │ ENCRYPTION_MODE=\"none\"     # or \"repokey-blake2\"   │"
echo "   │ BORG_PASSPHRASE=\"\"         # if encrypted          │"
echo "   │ NOTIFY_ADMIN_BACKUP=\"\"     # your email            │"
echo "   └─────────────────────────────────────────────────────┘"
echo ""
echo "   For REMOTE backups, also set:"
echo "   ┌─────────────────────────────────────────────────────────────────┐"
echo "   │ REMOTE_BACKUP_SERVER=\"u12345@u12345.your-storagebox.de\"       │"
echo "   │ REMOTE_BACKUP_PORT=\"23\"                                        │"
echo "   │ REMOTE_BACKUP_DIR=\"/home/borg\"                                 │"
echo "   │                                                                 │"
echo "   │ Option A: Password Authentication (simple, less secure)        │"
echo "   │   REMOTE_BACKUP_PASSWORD=\"your_password_here\"                 │"
echo "   │                                                                 │"
echo "   │ Option B: SSH Key Authentication (recommended, more secure)    │"
echo "   │   REMOTE_BACKUP_PASSWORD=\"\"  (leave empty)                    │"
echo "   │   Then setup SSH key:                                          │"
echo "   │     ssh-keygen -t ed25519 -f ~/.ssh/id_borg                    │"
echo "   │     ssh-copy-id -p 23 -i ~/.ssh/id_borg u12345@u12345.your-... │"
echo "   └─────────────────────────────────────────────────────────────────┘"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "2. TEST COMMANDS"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "   # Backup single user"
echo "   v-borg-backup-user admin"
echo ""
echo "   # List user backups"
echo "   v-borg-list-backups admin"
echo ""
echo "   # Restore user"
echo "   v-borg-restore-user 2025-10-17_12-30-00 admin"
echo ""
echo "   # Backup all users"
echo "   v-borg-backup-users"
echo ""
echo "   # Delete old backup"
echo "   v-borg-delete-backup admin 2025-10-17_12-30-00"
echo ""
echo "   # Prune all backups for user"
echo "   v-borg-backup-prune admin"
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "3. SETUP AUTOMATED BACKUPS (Optional)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
read -p "Add daily backup to cron (4 AM)? [y/N]: " -n 1 -r ADD_CRON
echo ""
if [[ "$ADD_CRON" =~ ^[Yy]$ ]]; then
    CRON_LINE='0 4 * * * /usr/local/vesta/bin/v-borg-backup-users > /var/log/borg/backup_$(date +\%F).log 2>&1'
    (crontab -l 2>/dev/null | grep -v v-borg-backup-users; echo "$CRON_LINE") | crontab -
    print_success "Cron job added (daily at 4 AM)"
else
    echo "   # Add manually via: crontab -e"
    echo "   # Then paste:"
    echo '   0 4 * * * /usr/local/vesta/bin/v-borg-backup-users > /var/log/borg/backup_$(date +\%F).log 2>&1'
fi
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "📁 Important Paths:"
echo "   Config: /usr/local/vesta/conf/borg.conf"
echo "   Logs:   /var/log/borg/"
echo "   Local:  /backup/borg/"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

print_success "Installation successful!"

exit 0


